---
import Base from '../../layouts/Base.astro';
import Topbar from '../../components/Topbar.astro';
import Screenshots from '../../components/Screenshots.astro';
import InfoPanel from '../../components/InfoPanel.astro';
import { loadApps, loadCatalog } from '../../lib/data.mjs';

export function getStaticPaths() {
  const { repo } = loadCatalog();
  return loadApps().map((app) => ({ params: { id: app.id }, props: { app, repo } }));
}

const { app, repo } = Astro.props;
const fallback = (app.name.match(/[A-Za-z0-9]/g) ?? []).slice(0, 2).join('').toUpperCase();
const latest = app.releases?.[0];

const detailRows = [
  app.developer && { label: 'Developer', value: app.developer },
  app.license && {
    label: 'License',
    value: app.license.label,
    href: app.license.url,
  },
  latest && { label: 'Version', value: `${latest.version}${latest.date ? ` · ${latest.date}` : ''}` },
  app.website && { label: 'Website', value: 'Homepage', href: app.website },
  app.urls?.help && { label: 'Support', value: 'Help & support', href: app.urls.help },
  app.sourceUrl && { label: 'Source', value: app.name, href: app.sourceUrl },
  app.packagingUrl && { label: 'Packaging', value: 'flatpark/registry', href: app.packagingUrl },
].filter(Boolean);

const hasShots = (app.screenshots?.length ?? 0) > 0;

// Inline <code> runs inside the About prose (e.g. a flatpak-override command).
// The About text sits on the canvas background, so the chip uses surface + a
// border to read as a distinct code token, and breaks rather than overflowing.
const codeRun =
  'rounded-md border border-line bg-surface px-1.5 py-0.5 font-mono text-[13px] text-ink break-words';

const pageUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ld = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: app.name,
  description: app.summary,
  applicationCategory: app.section || app.category,
  operatingSystem: 'Linux',
  url: pageUrl,
  ...(app.icon && Astro.site ? { image: new URL(app.icon, Astro.site).href } : {}),
  ...(latest?.version ? { softwareVersion: latest.version } : {}),
  ...(app.developer ? { author: { '@type': 'Organization', name: app.developer } } : {}),
};
---

<Base
  title={`Install ${app.name} on Linux — Flatpak | ${repo.title}`}
  description={`Install ${app.name} on any Linux distro (Fedora, Arch, Ubuntu, Bazzite) as a signed, sandboxed Flatpak. ${app.summary}`}
  image={app.icon}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(ld)} />
  <Topbar repo={repo} />
  <main>
    <div class="mx-auto max-w-5xl px-5 pt-6 text-sm text-muted">
      <a href="/" class="hover:text-ink">&larr; All apps</a>
    </div>

    <!-- header -->
    <section class="mx-auto max-w-5xl px-5 pt-4">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center">
        {
          app.icon ? (
            <img
              class="h-24 w-24 shrink-0 rounded-3xl border border-line bg-canvas object-contain p-3"
              src={app.icon}
              alt=""
              width="96"
              height="96"
            />
          ) : (
            <div class="grid h-24 w-24 shrink-0 place-items-center rounded-3xl bg-brand text-2xl font-black text-white">
              {fallback}
            </div>
          )
        }
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-2.5">
            <h1 class="text-3xl font-extrabold tracking-tight">{app.name}</h1>
            {app.featured && (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-brand/20 bg-brand/5 px-2.5 py-1 text-xs font-semibold text-brand" title="Published with the developer's approval">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" class="shrink-0" aria-hidden="true">
                  <path d="M12 1l9 4v6c0 5-3.8 9.7-9 11-5.2-1.3-9-6-9-11V5l9-4z"></path>
                </svg>
                Developer-approved
              </span>
            )}
          </div>
          <p class="mt-1 text-sm text-muted">
            {app.developer || 'Community package'}
            {app.proprietary ? <span class="ml-2 chip">Proprietary</span> : null}
          </p>
          <p class="mt-2 max-w-2xl text-muted">{app.summary}</p>
        </div>
        <div class="flex shrink-0 flex-col items-start gap-2 sm:items-end">
          <div class="relative inline-flex" data-install>
            <button
              type="button"
              class="inline-flex h-12 items-center gap-2 rounded-l-xl bg-brand pr-5 pl-6 text-base font-semibold text-white shadow-sm transition hover:bg-brand-dark"
              data-install-copy={app.installCmd}
              title={app.installCmd}
            >
              <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                <path d="M5.75 1A1.75 1.75 0 0 0 4 2.75v.5h-.25A1.75 1.75 0 0 0 2 5v8.25c0 .966.784 1.75 1.75 1.75h6.5A1.75 1.75 0 0 0 12 13.25v-.5h.25A1.75 1.75 0 0 0 14 11V5a.75.75 0 0 0-.22-.53l-3.25-3.25A.75.75 0 0 0 10 1H5.75ZM10 2.56 12.44 5H10V2.56ZM3.5 5c0-.138.112-.25.25-.25H4V11c0 .966.784 1.75 1.75 1.75H10.5v.5a.25.25 0 0 1-.25.25h-6.5a.25.25 0 0 1-.25-.25V5Z"></path>
              </svg>
              <span data-install-label>Install</span>
            </button>
            <button
              type="button"
              class="inline-flex h-12 items-center rounded-r-xl border-l border-white/25 bg-brand px-3 text-white transition hover:bg-brand-dark"
              data-install-toggle
              aria-haspopup="true"
              aria-expanded="false"
              aria-label="More install options"
            >
              <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                <path d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z"></path>
              </svg>
            </button>
            <div
              class="absolute top-[calc(100%+0.5rem)] right-0 z-30 w-72 overflow-hidden rounded-xl border border-line bg-surface text-left shadow-lg"
              data-install-menu
              hidden
            >
              <a href={app.refUrl} download class="flex items-start gap-3 px-4 py-3 hover:bg-canvas">
                <svg viewBox="0 0 16 16" fill="currentColor" class="mt-0.5 h-4 w-4 text-muted" aria-hidden="true">
                  <path d="M8 1a.75.75 0 0 1 .75.75v6.69l1.97-1.97a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.53a.75.75 0 0 1 1.06-1.06l1.97 1.97V1.75A.75.75 0 0 1 8 1Z"></path>
                  <path d="M2.75 10a.75.75 0 0 1 .75.75v1.75c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25V10.75a.75.75 0 0 1 1.5 0v1.75A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.5V10.75A.75.75 0 0 1 2.75 10Z"></path>
                </svg>
                <span>
                  <span class="block text-sm font-semibold text-ink">Download .flatpakref</span>
                  <span class="block text-xs text-muted">Open with your software installer</span>
                </span>
              </a>
            </div>
            <p
              data-install-hint
              hidden
              class="absolute top-[calc(100%+0.5rem)] right-0 z-30 w-64 rounded-xl border border-line bg-surface px-3 py-2 text-left text-xs text-muted shadow-lg"
            >
              Copied! Paste it into a terminal and press Enter to install.
            </p>
          </div>
          <a href="/setup/" class="text-xs text-muted hover:text-brand">First time? Set up {repo.title} &rarr;</a>
        </div>
      </div>

      <div class="mt-5 flex flex-wrap gap-2">
        <span class="chip">{app.section || app.category}</span>
        {app.license ? <span class="chip">{app.license.label}</span> : null}
        {latest ? <span class="chip">v{latest.version}</span> : null}
      </div>
    </section>

    {/* left column: screenshot carousel (if any) + About, stacked under the image;
        right column: the Details + Permissions panel. Keeping About on the left
        fills the space beside a tall info panel instead of leaving a big gap. */}
    <section class="mx-auto grid max-w-5xl items-start gap-8 px-5 py-10 lg:grid-cols-[1.7fr_1fr]">
      <div class="flex min-w-0 flex-col gap-8">
        {hasShots ? <Screenshots screenshots={app.screenshots} /> : null}
        <div>
          <h2 class="text-lg font-bold">About</h2>
          <div class="mt-3 flex flex-col gap-3 text-[15px] leading-relaxed text-ink/90">
            {
              app.description?.length > 0 ? (
                app.description.map((block) =>
                  block.type === 'list' ? (
                    <ul class="list-disc pl-5">
                      {block.items.map((item) => (
                        <li>{item.map((run) => ('code' in run ? <code class={codeRun}>{run.code}</code> : run.text))}</li>
                      ))}
                    </ul>
                  ) : (
                    <p>{block.runs.map((run) => ('code' in run ? <code class={codeRun}>{run.code}</code> : run.text))}</p>
                  ),
                )
              ) : (
                <p class="text-muted">{app.summary}</p>
              )
            }
          </div>
        </div>
      </div>
      <InfoPanel rows={detailRows} permissions={app.permissions} />
    </section>
  </main>

</Base>

---
import Base from '../layouts/Base.astro';
import Topbar from '../components/Topbar.astro';
import Hero from '../components/Hero.astro';
import AppCard from '../components/AppCard.astro';
import { loadCatalog } from '../lib/data.mjs';

const { repo, apps } = loadCatalog();
---

<Base title={repo.title}>
  <Topbar repo={repo} />
  <main>
    <Hero count={apps.length} />

    <section id="apps" class="mx-auto max-w-6xl px-5 pb-12">
      <div class="grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4 border-t border-line pt-8">
        {apps.map((app) => <AppCard app={app} />)}
      </div>
      <div
        class="rounded-2xl border border-dashed border-line p-12 text-center text-muted"
        data-empty
        hidden
      >
        <h2 class="font-bold text-ink">No matching apps</h2>
        <p>Try a different search.</p>
      </div>
    </section>
  </main>
</Base>

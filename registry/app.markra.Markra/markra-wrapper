#!/bin/sh
set -eu

# markra is a single self-contained Tauri (WebKitGTK) binary staged by
# apply_extra to /app/extra/markra/markra. It links only libraries in
# org.gnome.Platform (webkit2gtk-4.1, gtk-3). Flatpak redirects $HOME into the
# per-app data dir, so Markra's local documents and settings stay in the sandbox.

# WebKitGTK's DMABUF renderer paints a blank window under many drivers inside
# the Flatpak sandbox; the compositing path is the reliable default here.
export WEBKIT_DISABLE_DMABUF_RENDERER=1

exec /app/extra/markra/markra "$@"

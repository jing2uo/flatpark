#!/bin/sh
set -eu

APP=/app/extra/enpass

# Put our host-tool shims before runtime tools. Enpass uses lsof and /proc
# probes to verify the browser behind the extension WebSocket connection.
export PATH="/app/bin:/usr/bin"
export QT_QPA_PLATFORM=xcb
if [ -z "${ENPASS_FAKE_PID:-}" ]; then
    fake_pid=$(od -An -N4 -tu4 /dev/urandom 2>/dev/null | tr -d ' ')
    fake_pid=$((100000 + ${fake_pid:-0} % 800000))
    export ENPASS_FAKE_PID="$fake_pid"
fi
export LD_PRELOAD="/app/lib/enpass/libfakepid.so${LD_PRELOAD:+:$LD_PRELOAD}"

cd "$APP"
exec "$APP/Enpass" "$@"

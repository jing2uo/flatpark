# Cloudflare Pages caching. Hashed assets + fonts never change → cache forever;
# icons are stable per app id; catalog.json should revalidate often.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=86400

/catalog.json
  Cache-Control: public, max-age=300, must-revalidate
